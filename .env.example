# ============================================================
# x-ku-law 生产环境变量模板
# 使用方法：cp .env.example .env，填入真实值后勿提交至版本库
# ============================================================

# ===== MySQL（外部托管实例）=====
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=lr_law
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ===== Redis（外部托管实例）=====
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ===== RabbitMQ（外部托管实例，二期实现）=====
MQ_HOST=your-rabbitmq-host
MQ_PORT=5672
MQ_VHOST=/
MQ_USER=your-mq-user
MQ_PASSWORD=your-mq-password

# ===== Elasticsearch（外部托管实例；同时承载全文与向量 dense_vector/kNN）=====
ES_URIS=https://your-es-host:9200
ES_USERNAME=
ES_PASSWORD=
SEARCH_ENABLED=true

# ===== 向量检索（ES dense_vector，嵌入模型接入后再开启）=====
# 嵌入模型未接入前保持 false；EMBED_DIM 必须与所选模型维度一致。
VECTOR_ENABLED=false
EMBED_DIM=1536
AI_EMBED_MODEL_ID=text-embedding-3-small
# 真实嵌入客户端（OpenAI 兼容 /v1/embeddings）。false 时回退 NoOp（向量同步会空跑）。
EMBED_ENABLED=false
EMBED_BASE_URL=https://api.openai.com
EMBED_PATH=/v1/embeddings
EMBED_API_KEY=

# ===== 采集批量接入（外部 Python 抓取 -> MinIO；Java 按 cron 定时读取接入）=====
# enabled 默认 false；COLLECT_CRON 为定时批量接入时刻（默认每月 1 日 03:00），不再每隔数分钟轮询扫描。
COLLECT_ENABLED=false
COLLECT_CRON=0 0 3 1 * ?
COLLECT_BATCH_SIZE=5
COLLECT_TIMEOUT_MIN=30
# 初始全量历史回填时置 true，抑制海量订阅预警；增量接入保持 false。
COLLECT_SUPPRESS_ALERTS=false

# ===== 法规处理管线（结构化先行 / AI 旁路）=====
# 主管线只跑结构化阶段（文本提取->分段->发布->变更分析->AI入队），不触发 LLM。
# enabled 默认 false；接入数据后置 true 才会异步消费 lr_law_process_task。
# 首次 2 万+ 文件回填：调大 batch/并发加速；结构化只需 EMBED_API_KEY（向量），不需 AI key。
PROCESS_ENABLED=false
PROCESS_INTERVAL=10000
PROCESS_MAX_RETRY=3
PROCESS_TIMEOUT_MIN=30
PROCESS_BATCH_SIZE=20
PROCESS_CONCURRENCY=4
PROCESS_SEGMENT_MAX_CHARS=1000

# ===== AI 旁路（摘要/标签/整篇解读；需 AI 模型 apikey，见下方 AI 模型）=====
# 结构化先行：默认 false。提供 AI key 后置 true，存量历史用 POST /ops/ai-tasks/backfill 回填全库。
# batch/并发默认更小以尊重 LLM 限流。
PROCESS_AI_ENABLED=false
PROCESS_AI_INTERVAL=10000
PROCESS_AI_MAX_RETRY=3
PROCESS_AI_TIMEOUT_MIN=30
PROCESS_AI_BATCH_SIZE=5
PROCESS_AI_CONCURRENCY=2
PROCESS_METADATA_MAX_INPUT_CHARS=6000
PROCESS_INTERPRETATION_MAX_INPUT_CHARS=8000

# ===== 安全配置（必须替换，禁止使用默认值）=====
# 生成方式：openssl rand -base64 32
JWT_SECRET=your-random-256bit-base64-secret
JWT_ACCESS_TTL=7200
JWT_REFRESH_TTL=604800

# ===== 对象存储（MinIO / S3 兼容，前端直传预签名）=====
# 前端直传链路：后端签发预签名 PUT URL -> 前端 PUT 文件 -> 后端 /complete HEAD 校验落库。
# 私有桶需在桶上配置 CORS，允许前端 Origin 的 PUT 并 expose ETag，否则浏览器跨域 PUT 会被拦截。
OSS_ENDPOINT=https://your-oss-endpoint
OSS_BUCKET=lr-law
OSS_ACCESS_KEY=your-access-key
OSS_SECRET_KEY=your-secret-key
OSS_PRESIGN_EXPIRE=600
OSS_MAX_FILE_SIZE=52428800
OSS_PUBLIC_READ=false

# ===== AI 模型（摘要/标签/整篇解读 + 可溯源问答 Agent 已接入）=====
# 提供其一的 api-key 即可：默认 provider 由 AI_DEFAULT_PROVIDER 指定；未配 key 的 provider 自动不注册。
# 配好 key 后置 PROCESS_AI_ENABLED=true 即可生成解读；问答 Agent 直接复用此处 provider。
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL_ID=gpt-4o
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
QWEN_MODEL_ID=qwen-plus

# ===== AI 可溯源问答（Agent 自主检索 + SSE 流式；均有默认值，可不配）=====
# 检索质量依赖全文检索(SEARCH_ENABLED)与语义检索(VECTOR_ENABLED+EMBED_ENABLED)；未启用时 Agent 会如实说明依据不足。
# 历史原文回灌的字符预算，超过则把较旧轮次增量折叠进滚动摘要
AI_CHAT_CONTEXT_CHAR_BUDGET=6000
# 至少保留多少条最近消息为原文（不被摘要吞掉）
AI_CHAT_KEEP_RECENT_MESSAGES=6
# 每次折叠进摘要的最旧消息条数
AI_CHAT_SUMMARIZE_BATCH_SIZE=4
# 并发流式会话上限
AI_CHAT_MAX_CONCURRENCY=8

# ===== 部署配置（可选）=====
APP_IMAGE=x-ku-law:latest
APP_PORT=8080
